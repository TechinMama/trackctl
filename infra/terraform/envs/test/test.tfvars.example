environment = "test"
location    = "eastus2"

# Optional: set this when globally-unique names like Key Vault or PostgreSQL
# conflict with existing names in Azure.
resource_name_suffix = ""

container_image = "<acr-login-server>/athena-backend:test"

# Pre-production profile with enough baseline capacity for validation.
container_min_replicas = 1
container_max_replicas = 2
container_cpu          = 0.5
container_memory       = "1.0Gi"

acr_sku            = "Standard"
log_retention_days = 30
servicebus_sku     = "Standard"

postgres_sku_name   = "B_Standard_B2ms"
postgres_storage_mb = 65536

# Provide postgres_admin_password through secure means, for example:
# export TF_VAR_postgres_admin_password="..."

tags = {
  owner = "athena"
}
