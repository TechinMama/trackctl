environment = "dev"
location    = "eastus2"

# Optional: set this when globally-unique names like Key Vault or PostgreSQL
# conflict with existing names in Azure.
resource_name_suffix = ""

container_image = "<acr-login-server>/athena-backend:dev"

# Cost-efficient defaults until traffic arrives.
container_min_replicas = 0
container_max_replicas = 1
container_cpu          = 0.25
container_memory       = "0.5Gi"

acr_sku            = "Basic"
log_retention_days = 30
servicebus_sku     = "Basic"

postgres_sku_name   = "B_Standard_B1ms"
postgres_storage_mb = 32768

# Provide postgres_admin_password through secure means, for example:
# export TF_VAR_postgres_admin_password="..."

tags = {
  owner = "athena"
}
